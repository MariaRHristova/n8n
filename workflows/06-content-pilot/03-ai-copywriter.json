      "parameters": {
        "jsCode": "const ai = JSON.parse($input.first().json.text);\n\nconst content = `Meta Title: ${ai.meta_title}\\n\\nMeta Description: ${ai.meta_description}\\n\\nIntro:\\n${ai.intro}`;\n\nconst prompt = $input.first().json.prompt || '';\nconst titleMatch = prompt.match(/темата \"([^\"]+)\"/);\nreturn [{ json: { content, title: `ContentPilot Draft - ${titleMatch ? titleMatch[1] : 'Draft'}` } }];"
      },
