    {
      "parameters": {
        "jsCode": "const ai = JSON.parse($input.first().json.text);\n\nconst content = `Meta Title: ${ai.meta_title}\n\nMeta Description: ${ai.meta_description}\n\nIntro:\n${ai.intro}`;\n\nconst platform = `${ai.meta_platform || 'wordpress'}`;\n\nconst prompt = $input.first().json.prompt || '';\nconst titleMatch = prompt.match(/темата \"([^\"]+)\"/);\n\nreturn [\n  {\n    json: {\n      content,\n      title: `ContentPilot Draft - ${titleMatch ? titleMatch[1] : 'Draft'}`,\n      platform,\n    },\n  },\n];"
      },
